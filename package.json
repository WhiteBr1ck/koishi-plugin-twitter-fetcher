{
  "name": "koishi-plugin-twitter-fetcher",
  "description": "一个推特/Twitter/X内容获取与订阅插件，支持链接实时解析和用户后台订阅推送。",
  "version": "2.0.1",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib",
    "dist",
    "client"
  ],
  "author": "whitebr1ck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WhiteBr1ck/koishi-plugin-twitter-fetcher.git"
  },
  "bugs": {
    "url": "https://github.com/WhiteBr1ck/koishi-plugin-twitter-fetcher/issues"
  },
  "homepage": "https://github.com/WhiteBr1ck/koishi-plugin-twitter-fetcher#readme",
  "keywords": [
    "koishi",
    "plugin",
    "twitter",
    "x",
    "fetcher",
    "parse",
    "resolver",
    "subscribe",
    "subscription",
    "push",
    "gif",
    "ffmpeg",
    "browser"
  ],
  "peerDependencies": {
    "@koishijs/plugin-console": "^5.30.0",
    "koishi": "^4.18.7",
    "koishi-plugin-ffmpeg": "^1.1.0",
    "koishi-plugin-puppeteer": "*"
  },
  "koishi": {
    "description": {
      "zh": "自动解析推特/Twitter/X链接，聚合内容。支持订阅推送、浏览器原生获取、真 GIF 和多种媒体发送方式。"
    },
    "service": {
      "required": [
        "puppeteer",
        "database"
      ],
      "optional": [
        "console",
        "ffmpeg"
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node18 --external:koishi --external:koishi-plugin-puppeteer --external:@koishijs/plugin-console --outfile=lib/index.js && tsc --emitDeclarationOnly"
  },
  "peerDependenciesMeta": {
    "@koishijs/plugin-console": {
      "optional": true
    },
    "koishi-plugin-ffmpeg": {
      "optional": true
    }
  }
}
